# ─────────────────────────────────────────────────────────────
# LEAP Presentation — Firebase configuration
# Copy this file to .env.local and fill in your values from:
#   https://console.firebase.google.com → Project Settings → Your apps → Web app
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Public URL of your deployed app — used for QR code on the Summary slide
# After deploying to Firebase, set this to https://your-project-id.web.app
VITE_APP_URL=https://your-project-id.web.app
